generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ImportIssueSeverity {
  WARNING
  ERROR
}

enum OrderStatus {
  FAKE_PAID
  REJECTED
}

model Category {
  id             String    @id @default(cuid())
  name           String
  normalizedName String    @unique
  products       Product[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Product {
  id          String      @id @default(cuid())
  sku         String      @unique
  name        String
  description String?
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  priceCents  Int
  stock       Int
  weightGrams Int?
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([name])
  @@index([sku])
  @@index([categoryId])
}

model ImportRun {
  id           String        @id @default(cuid())
  fileName     String?
  createdCount Int           @default(0)
  updatedCount Int           @default(0)
  skippedCount Int           @default(0)
  issueCount   Int           @default(0)
  issues       ImportIssue[]
  createdAt    DateTime      @default(now())
}

model ImportIssue {
  id          String              @id @default(cuid())
  importRunId String
  importRun   ImportRun           @relation(fields: [importRunId], references: [id], onDelete: Cascade)
  rowNumber   Int
  field       String?
  severity    ImportIssueSeverity
  message     String
  createdAt   DateTime            @default(now())

  @@index([importRunId])
}

model Order {
  id          String      @id @default(cuid())
  buyerName   String
  buyerEmail  String
  status      OrderStatus @default(FAKE_PAID)
  totalCents  Int
  items       OrderItem[]
  createdAt   DateTime    @default(now())
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String?
  product        Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  skuSnapshot    String
  nameSnapshot   String
  unitPriceCents Int
  quantity       Int
  lineTotalCents Int

  @@index([orderId])
  @@index([productId])
}
